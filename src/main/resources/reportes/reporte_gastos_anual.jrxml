<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="reporte_gastos_anual" pageWidth="210" pageHeight="297"
              columnWidth="190" leftMargin="10" rightMargin="10"
              topMargin="10" bottomMargin="10">

    <parameter name="titulo" class="java.lang.String"/>
    <parameter name="anio" class="java.lang.Integer"/>

    <title>
        <band height="60">
            <staticText>
                <reportElement x="0" y="0" width="190" height="25"/>
                <textElement>
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Reporte de Gastos]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="25" width="190" height="15"/>
                <textFieldExpression><![CDATA[$P{titulo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="40" width="190" height="15"/>
                <textFieldExpression><![CDATA[$P{anio}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="40" height="20"/>
                <box topBorder="Thin" bottomBorder="Thin" leftBorder="Thin"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Mes]]></text>
            </staticText>
            <staticText>
                <reportElement x="40" y="0" width="90" height="20"/>
                <box topBorder="Thin" bottomBorder="Thin"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Categoría]]></text>
            </staticText>
            <staticText>
                <reportElement x="130" y="0" width="60" height="20"/>
                <box topBorder="Thin" bottomBorder="Thin"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Descripción]]></text>
            </staticText>
            <staticText>
                <reportElement x="190" y="0" width="0" height="20"/>
                <box topBorder="Thin" bottomBorder="Thin" rightBorder="Thin"/>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="15">
            <textField>
                <reportElement x="0" y="0" width="40" height="15"/>
                <box leftBorder="Thin" bottomBorder="Thin"/>
                <textFieldExpression><![CDATA[$F{mes}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="40" y="0" width="90" height="15"/>
                <box bottomBorder="Thin"/>
                <textFieldExpression><![CDATA[$F{categoria}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="130" y="0" width="60" height="15"/>
                <box bottomBorder="Thin"/>
                <textFieldExpression><![CDATA[$F{descripcion}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="40">
            <staticText>
                <reportElement x="0" y="10" width="160" height="15"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Total Gastos:]]></text>
            </staticText>
            <textField>
                <reportElement x="160" y="10" width="30" height="15"/>
                <textFieldExpression><![CDATA[$P{total_gastos}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>