<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="recibo" pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              whenNoDataType="AllSectionsNoDetail">

    <parameter name="RECIBO_NUMERO" class="java.lang.String"/>
    <parameter name="FECHA_EMISION" class="java.lang.String"/>
    <parameter name="EMISOR_CUIT" class="java.lang.String"/>
    <parameter name="EMISOR_RAZON_SOCIAL" class="java.lang.String"/>
    <parameter name="EMISOR_CONDICION_IVA" class="java.lang.String"/>
    <parameter name="PAGADOR_CUIT" class="java.lang.String"/>
    <parameter name="PAGADOR_RAZON_SOCIAL" class="java.lang.String"/>
    <parameter name="MONTO_TOTAL" class="java.math.BigDecimal"/>
    <parameter name="MONTO_LETRAS" class="java.lang.String"/>
    <parameter name="FORMAS_PAGO_TEXTO" class="java.lang.String"/>
    <parameter name="OBSERVACIONES" class="java.lang.String"/>

    <field name="numeroFactura" class="java.lang.String"/>
    <field name="montoAplicado" class="java.math.BigDecimal"/>
    <field name="tipoComprobanteStr" class="java.lang.String"/>

    <title>
        <band height="420">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="50"/>
                <graphicElement>
                    <pen lineWidth="2"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="0" width="535" height="50"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="22" isBold="true"/>
                </textElement>
                <text><![CDATA[RECIBO]]></text>
            </staticText>

            <textField isBlankWhenNull="true">
                <reportElement x="0" y="58" width="535" height="18"/>
                <textElement textAlignment="Center">
                    <font fontName="Arial" size="12" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Recibo Nro: " + $P{RECIBO_NUMERO}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="0" y="78" width="535" height="16"/>
                <textElement textAlignment="Center">
                    <font fontName="Arial" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["Fecha: " + $P{FECHA_EMISION}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="0" y="102" width="535" height="20"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="102" width="535" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[DATOS DEL EMISOR]]></text>
            </staticText>

            <rectangle>
                <reportElement x="0" y="124" width="535" height="60"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>
            <textField isBlankWhenNull="true">
                <reportElement x="10" y="127" width="515" height="15"/>
                <textElement><font fontName="Arial" size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["CUIT: " + $P{EMISOR_CUIT}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="10" y="144" width="515" height="15"/>
                <textElement><font fontName="Arial" size="9"/></textElement>
                <textFieldExpression><![CDATA["Razon Social: " + $P{EMISOR_RAZON_SOCIAL}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="10" y="161" width="515" height="15"/>
                <textElement><font fontName="Arial" size="9"/></textElement>
                <textFieldExpression><![CDATA["Condicion IVA: " + $P{EMISOR_CONDICION_IVA}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="0" y="190" width="535" height="20"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="190" width="535" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[DATOS DEL PAGADOR]]></text>
            </staticText>

            <rectangle>
                <reportElement x="0" y="212" width="535" height="40"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>
            <textField isBlankWhenNull="true">
                <reportElement x="10" y="215" width="515" height="15"/>
                <textElement><font fontName="Arial" size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["CUIT: " + $P{PAGADOR_CUIT}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="10" y="232" width="515" height="15"/>
                <textElement><font fontName="Arial" size="9"/></textElement>
                <textFieldExpression><![CDATA["Razon Social: " + $P{PAGADOR_RAZON_SOCIAL}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="0" y="258" width="535" height="20"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="258" width="535" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[FACTURAS ASOCIADAS]]></text>
            </staticText>

            <rectangle>
                <reportElement x="0" y="280" width="535" height="18"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="5" y="281" width="250" height="16"/>
                <textElement verticalAlignment="Middle"><font fontName="Arial" size="8" isBold="true"/></textElement>
                <text><![CDATA[Comprobante]]></text>
            </staticText>
            <staticText>
                <reportElement x="310" y="281" width="100" height="16"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Arial" size="8" isBold="true"/></textElement>
                <text><![CDATA[Monto Aplicado]]></text>
            </staticText>
        </band>
    </title>

    <detail>
        <band height="16">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="16"/>
                <graphicElement>
                    <pen lineWidth="0.2"/>
                </graphicElement>
            </rectangle>
            <textField isBlankWhenNull="true">
                <reportElement x="5" y="0" width="300" height="16"/>
                <textElement verticalAlignment="Middle"><font fontName="Arial" size="8"/></textElement>
                <textFieldExpression><![CDATA[($F{tipoComprobanteStr} != null ? $F{tipoComprobanteStr} + " " : "") + ($F{numeroFactura} != null ? $F{numeroFactura} : "")]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="310" y="0" width="215" height="16"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Arial" size="8"/></textElement>
                <textFieldExpression><![CDATA["$ " + $F{montoAplicado}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="260">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="20"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="0" width="535" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[FORMAS DE PAGO]]></text>
            </staticText>

            <rectangle>
                <reportElement x="0" y="22" width="535" height="45"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>
            <textField isBlankWhenNull="true">
                <reportElement x="10" y="25" width="515" height="38"/>
                <textElement><font fontName="Arial" size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{FORMAS_PAGO_TEXTO}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="0" y="72" width="535" height="55"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>
            <textField isBlankWhenNull="true">
                <reportElement x="10" y="77" width="300" height="14"/>
                <textElement><font fontName="Arial" size="9"/></textElement>
                <textFieldExpression><![CDATA["Total en letras: " + $P{MONTO_LETRAS}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="320" y="77" width="205" height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font fontName="Arial" size="14" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["$ " + $P{MONTO_TOTAL}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="320" y="98" width="205" height="1"/>
            </line>
            <staticText>
                <reportElement x="320" y="100" width="205" height="10"/>
                <textElement textAlignment="Right"><font fontName="Arial" size="7"/></textElement>
                <text><![CDATA[Total]]></text>
            </staticText>

            <textField isBlankWhenNull="true">
                <reportElement x="10" y="135" width="515" height="15"/>
                <textElement><font fontName="Arial" size="9"/></textElement>
                <textFieldExpression><![CDATA["Observaciones: " + $P{OBSERVACIONES}]]></textFieldExpression>
            </textField>

            <rectangle>
                <reportElement x="0" y="160" width="535" height="20"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="0" y="160" width="535" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[FIRMA / SELLO]]></text>
            </staticText>

            <rectangle>
                <reportElement x="0" y="182" width="535" height="60"/>
                <graphicElement>
                    <pen lineWidth="0.5"/>
                </graphicElement>
            </rectangle>
            <line>
                <reportElement x="100" y="220" width="335" height="1"/>
            </line>
            <staticText>
                <reportElement x="100" y="222" width="335" height="15"/>
                <textElement textAlignment="Center"><font fontName="Arial" size="8"/></textElement>
                <text><![CDATA[Firma y aclaracion del emisor / Sello de la empresa]]></text>
            </staticText>
        </band>
    </summary>
</jasperReport>
