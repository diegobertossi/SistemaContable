<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="factura_a" pageWidth="210" pageHeight="297"
              columnWidth="190" leftMargin="10" rightMargin="10"
              topMargin="10" bottomMargin="10">

    <title>
        <band height="80">
            <staticText>
                <reportElement x="0" y="0" width="190" height="30"/>
                <textElement>
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[FACTURA A]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="35" width="100" height="15"/>
                <textElement><font size="10"/></textElement>
                <text><![CDATA[Razón Social:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="35" width="90" height="15"/>
                <textFieldExpression><![CDATA[$P{RAZON_SOCIAL_EMISOR}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="0" y="50" width="60" height="15"/>
                <textElement><font size="10"/></textElement>
                <text><![CDATA[CUIT:]]></text>
            </staticText>
            <textField>
                <reportElement x="60" y="50" width="130" height="15"/>
                <textFieldExpression><![CDATA[$P{CUIT_EMISOR}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="190" height="20"/>
                <box topBorder="Thin" bottomBorder="Thin"/>
                <textElement>
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[COMPROBANTE]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="150">
            <staticText>
                <reportElement x="0" y="10" width="60" height="15"/>
                <text><![CDATA[Punto de Venta:]]></text>
            </staticText>
            <textField>
                <reportElement x="60" y="10" width="130" height="15"/>
                <textFieldExpression><![CDATA[$P{PUNTO_VENTA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="25" width="60" height="15"/>
                <text><![CDATA[Número:]]></text>
            </staticText>
            <textField>
                <reportElement x="60" y="25" width="130" height="15"/>
                <textFieldExpression><![CDATA[$P{NUMERO_COMPROBANTE}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="40" width="60" height="15"/>
                <text><![CDATA[Fecha:]]></text>
            </staticText>
            <textField>
                <reportElement x="60" y="40" width="130" height="15"/>
                <textFieldExpression><![CDATA[$P{FECHA_EMISION}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="60" width="190" height="1">
                    <box>
                        <topPen lineWidth="0.5"/>
                    </box>
                </reportElement>
            </staticText>

            <staticText>
                <reportElement x="0" y="70" width="95" height="15"/>
                <text><![CDATA[Receptor:]]></text>
            </staticText>
            <textField>
                <reportElement x="95" y="70" width="95" height="15"/>
                <textFieldExpression><![CDATA[$P{RAZON_SOCIAL_RECEPTOR}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="85" width="60" height="15"/>
                <text><![CDATA[CUIT:]]></text>
            </staticText>
            <textField>
                <reportElement x="60" y="85" width="130" height="15"/>
                <textFieldExpression><![CDATA[$P{CUIT_RECEPTOR}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="105" width="190" height="1">
                    <box>
                        <topPen lineWidth="0.5"/>
                    </box>
                </reportElement>
            </staticText>

            <staticText>
                <reportElement x="0" y="115" width="100" height="15"/>
                <text><![CDATA[Importe Neto:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="115" width="90" height="15"/>
                <textFieldExpression><![CDATA[$P{IMPORTE_NETO}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="130" width="100" height="15"/>
                <text><![CDATA[IVA:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="130" width="90" height="15"/>
                <textFieldExpression><![CDATA[$P{IMPORTE_IVA}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="145" width="100" height="15">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[TOTAL:]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="145" width="90" height="15">
                    <textElement>
                        <font isBold="true" size="12"/>
                    </textElement>
                </textElement>
                <textFieldExpression><![CDATA[$P{IMPORTE_TOTAL}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <pageFooter>
        <band height="40">
            <staticText>
                <reportElement x="0" y="0" width="95" height="15"/>
                <text><![CDATA[CAE:]]></text>
            </staticText>
            <textField>
                <reportElement x="95" y="0" width="95" height="15"/>
                <textFieldExpression><![CDATA[$P{CAE}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="15" width="95" height="15"/>
                <text><![CDATA[Vencimiento CAE:]]></text>
            </staticText>
            <textField>
                <reportElement x="95" y="15" width="95" height="15"/>
                <textFieldExpression><![CDATA[$P{VENCIMIENTO_CAE}]]></textFieldExpression>
            </textField>

            <image>
                <reportElement x="0" y="25" width="50" height="15"/>
                <imageExpression><![CDATA[$P{QR_BASE64}]]></imageExpression>
            </image>
        </band>
    </pageFooter>
</jasperReport>