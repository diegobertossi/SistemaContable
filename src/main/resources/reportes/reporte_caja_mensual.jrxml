<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="reporte_caja_mensual" pageWidth="210" pageHeight="297"
              columnWidth="190" leftMargin="10" rightMargin="10"
              topMargin="10" bottomMargin="10">

    <parameter name="titulo" class="java.lang.String"/>
    <parameter name="periodo" class="java.lang.String"/>

    <title>
        <band height="60">
            <staticText>
                <reportElement x="0" y="0" width="190" height="25"/>
                <textElement>
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Reporte de Caja]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="25" width="190" height="15"/>
                <textFieldExpression><![CDATA[$P{titulo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="40" width="190" height="15"/>
                <textFieldExpression><![CDATA[$P{periodo}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="50" height="20"/>
                <box topBorder="Thin" bottomBorder="Thin" leftBorder="Thin"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Fecha]]></text>
            </staticText>
            <staticText>
                <reportElement x="50" y="0" width="50" height="20"/>
                <box topBorder="Thin" bottomBorder="Thin"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Tipo]]></text>
            </staticText>
            <staticText>
                <reportElement x="100" y="0" width="60" height="20"/>
                <box topBorder="Thin" bottomBorder="Thin"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Descripción]]></text>
            </staticText>
            <staticText>
                <reportElement x="160" y="0" width="30" height="20"/>
                <box topBorder="Thin" bottomBorder="Thin" rightBorder="Thin"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Monto]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="15">
            <textField>
                <reportElement x="0" y="0" width="50" height="15"/>
                <box leftBorder="Thin" bottomBorder="Thin"/>
                <textFieldExpression><![CDATA[$F{fecha}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="50" y="0" width="50" height="15"/>
                <box bottomBorder="Thin"/>
                <textFieldExpression><![CDATA[$F{tipo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="100" y="0" width="60" height="15"/>
                <box bottomBorder="Thin"/>
                <textFieldExpression><![CDATA[$F{descripcion}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="160" y="0" width="30" height="15"/>
                <box bottomBorder="Thin" rightBorder="Thin"/>
                <textFieldExpression><![CDATA[$F{monto}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="40">
            <staticText>
                <reportElement x="0" y="10" width="160" height="15"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Total Cobros:]]></text>
            </staticText>
            <textField>
                <reportElement x="160" y="10" width="30" height="15"/>
                <textFieldExpression><![CDATA[$P{total_cobros}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="25" width="160" height="15"/>
                <textElement><font isBold="true"/></textElement>
                <text><![CDATA[Total Pagos:]]></text>
            </staticText>
            <textField>
                <reportElement x="160" y="25" width="30" height="15"/>
                <textFieldExpression><![CDATA[$P{total_pagos}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>